; Map 45x16 tiles (tile ids)
map:
	.db 9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9,9
	.db 9,9,10,10,10,10,10,0,0,9,9,9,9,10,10,10,10,10,10,10,0,0,0,0,10,0,0,0,0,0,0,14,0,0,0,10,10,10,10,10,10,10,10,9,9
	.db 9,10,10,10,11,0,1,0,4,0,9,9,9,10,0,0,10,10,10,0,0,5,0,0,10,0,13,0,4,0,0,0,1,0,0,13,0,0,0,0,0,10,10,10,9
